# Magic Link Authentication Configuration
# Copy this file to .env and fill in your actual values

# Application Settings
APP_NAME=Wheelder
APP_URL=http://localhost

# Email Service Provider (smtp, sendgrid, or mailgun)
EMAIL_PROVIDER=smtp

# SMTP Configuration (for DigitalOcean App Platform or traditional SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@wheelder.com
SMTP_FROM_NAME=Wheelder

# SendGrid Configuration (if using SendGrid)
# SENDGRID_API_KEY=your-sendgrid-api-key
# SENDGRID_FROM_EMAIL=noreply@wheelder.com
# SENDGRID_FROM_NAME=Wheelder

# Mailgun Configuration (if using Mailgun)
# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_DOMAIN=mg.wheelder.com
# MAILGUN_FROM_EMAIL=noreply@wheelder.com
# MAILGUN_FROM_NAME=Wheelder

# Database
DATABASE_PATH=pool/config/wheelder.db

# Session Settings
SESSION_TIMEOUT=1800
SESSION_ABSOLUTE_TIMEOUT=86400
